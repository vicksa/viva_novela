# JWT
JWT_SECRET=seu-segredo-super-seguro-aqui

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081,http://localhost:5173

# Postgres (Render managed database) - External Database URL
DATABASE_URL=postgresql://usuario:senha@host.render.com/viva_novela

# Cloudinary (upload de capas) - encontre em Dashboard > Product Environment Credentials
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

